{
  "name": "exsorted",
  "version": "1.1.2",
  "description": "A lightweight, fully-typed TypeScript sorting library with 19 algorithms: bubble, insertion, selection, merge, quick, heap, tim, gnome, shell, intro, block, counting, radix, bucket, pigeonhole, cycle, bitonic, cocktail shaker, and comb sort. Supports ESM and CJS, tree-shakeable, zero dependencies.",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "benchmark": "pnpm run build && node scripts/benchmark.cjs",
    "benchmark:block": "pnpm run build && node scripts/benchmark-block.cjs",
    "test:integration": "pnpm run build && node scripts/integration.cjs",
    "minify": "tsup --config tsup.config.ts --minify",
    "test": "jest",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "typecheck": "tsc --noEmit",
    "release:check": "pnpm run lint && pnpm run typecheck && pnpm exec jest --ci && pnpm run test:integration",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky",
    "prepublishOnly": "pnpm run release:check && pnpm run minify",
    "run:example": "tsx src/playground/index.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
