{
  "name": "exsorted",
  "version": "1.0.5",
  "description": "A TypeScript sorting algorithms library",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "benchmark": "pnpm run build && node scripts/benchmark.cjs",
    "minify": "tsup --config tsup.config.ts --minify",
    "test": "jest",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky",
    "prepublishOnly": "pnpm run minify"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./base": {
      "types": "./dist/sorted/base/index.d.ts",
      "import": "./dist/sorted/base/index.mjs",
      "require": "./dist/sorted/base/index.cjs"
    },
    "./meme": {
      "types": "./dist/sorted/meme/index.d.ts",
      "import": "./dist/sorted/meme/index.mjs",
      "require": "./dist/sorted/meme/index.cjs"
    },
    "./standard": {
      "types": "./dist/sorted/standard/index.d.ts",
      "import": "./dist/sorted/standard/index.mjs",
      "require": "./dist/sorted/standard/index.cjs"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.mjs",
      "require": "./dist/types/index.cjs"
    },
    "./helper": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.mjs",
      "require": "./dist/utils/index.cjs"
    },
    "./bubble": {
      "types": "./dist/sorted/base/bubble/index.d.ts",
      "import": "./dist/sorted/base/bubble/index.mjs",
      "require": "./dist/sorted/base/bubble/index.cjs"
    },
    "./insertion": {
      "types": "./dist/sorted/base/insertion/index.d.ts",
      "import": "./dist/sorted/base/insertion/index.mjs",
      "require": "./dist/sorted/base/insertion/index.cjs"
    },
    "./selection": {
      "types": "./dist/sorted/base/selection/index.d.ts",
      "import": "./dist/sorted/base/selection/index.mjs",
      "require": "./dist/sorted/base/selection/index.cjs"
    },
    "./merge": {
      "types": "./dist/sorted/base/merge/index.d.ts",
      "import": "./dist/sorted/base/merge/index.mjs",
      "require": "./dist/sorted/base/merge/index.cjs"
    },
    "./quick": {
      "types": "./dist/sorted/base/quick/index.d.ts",
      "import": "./dist/sorted/base/quick/index.mjs",
      "require": "./dist/sorted/base/quick/index.cjs"
    },
    "./heap": {
      "types": "./dist/sorted/base/heap/index.d.ts",
      "import": "./dist/sorted/base/heap/index.mjs",
      "require": "./dist/sorted/base/heap/index.cjs"
    },
    "./tim": {
      "types": "./dist/sorted/standard/tim/index.d.ts",
      "import": "./dist/sorted/standard/tim/index.mjs",
      "require": "./dist/sorted/standard/tim/index.cjs"
    },
    "./gnome": {
      "types": "./dist/sorted/standard/gnome/index.d.ts",
      "import": "./dist/sorted/standard/gnome/index.mjs",
      "require": "./dist/sorted/standard/gnome/index.cjs"
    },
    "./shell": {
      "types": "./dist/sorted/standard/shell/index.d.ts",
      "import": "./dist/sorted/standard/shell/index.mjs",
      "require": "./dist/sorted/standard/shell/index.cjs"
    },
    "./intro": {
      "types": "./dist/sorted/standard/intro/index.d.ts",
      "import": "./dist/sorted/standard/intro/index.mjs",
      "require": "./dist/sorted/standard/intro/index.cjs"
    },
    "./block": {
      "types": "./dist/sorted/standard/block/index.d.ts",
      "import": "./dist/sorted/standard/block/index.mjs",
      "require": "./dist/sorted/standard/block/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,mjs,cjs}": [
      "oxlint --fix"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ink01101011/exsorted.git"
  },
  "keywords": [
    "sort",
    "sorting",
    "algorithms",
    "typescript",
    "bubble-sort",
    "merge-sort",
    "quick-sort",
    "heap-sort",
    "insertion-sort",
    "selection-sort",
    "tim-sort",
    "gnome-sort",
    "shell-sort",
    "intro-sort",
    "block-sort",
    "exsorted"
  ],
  "author": "Ink01101011",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Ink01101011/exsorted/issues"
  },
  "homepage": "https://github.com/Ink01101011/exsorted#readme",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.58.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.8",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
