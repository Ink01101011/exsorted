  "sideEffects": false,
  "files": [
    "dist"
  ],
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,mjs,cjs}": [
      "oxlint --fix"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ink01101011/exsorted.git"
  },
  "keywords": [
    "sort",
    "sorting",
    "algorithms",
